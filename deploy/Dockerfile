FROM golang:1.24-alpine AS build
WORKDIR /src

RUN apk add --no-cache git

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/api ./cmd/api

FROM alpine:3.19
WORKDIR /app

COPY --from=build /bin/api /app/api
COPY migrations /app/migrations

EXPOSE 8080
ENTRYPOINT ["/app/api"]
